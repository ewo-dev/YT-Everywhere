{
  "manifest_version": 3,
  "name": "YT Everywhere",
  "version": "1.0.0",
  "description": "Search YouTube instantly from anywhere on the web",
  "permissions": ["tabs", "scripting"],
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Toggle YouTube search overlay"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["styles/overlay.css"]
    }
  ],
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  }
  ,
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-everywhere@ewo-dev.com",
      "strict_min_version": "115.0"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
